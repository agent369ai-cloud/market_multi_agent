# Copy this file to .env and fill in real values. .env is gitignored — never commit real keys.

# Groq (synthesizer LLM, OpenAI-compatible client)
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile
SYNTHESIZER_TEMPERATURE=0.3
SYNTHESIZER_MAX_TOKENS=600

# Cohere (embeddings for RAG)
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-english-v3.0

# Pinecone (vector search for RAG)
PINECONE_API_KEY=
PINECONE_ENV=us-east-1
PINECONE_INDEX_NAME=market-support-docs

# Postgres (SQL agent + conversation memory) — defaults match docker-compose.yml
DATABASE_URL=postgresql://Market:Market_dev_pw@localhost:5432/Market

LOG_LEVEL=INFO
ENV=dev
